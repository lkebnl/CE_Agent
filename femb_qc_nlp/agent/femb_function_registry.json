{
  "version": "2.0.0",
  "description": "FEMB QC system complete instruction registry (Phase 1 + Phase 2)",

  "layer0_init": {
    "wib_ping":      {"nl_triggers": ["ping", "check WIB", "is WIB online"], "params": {}},
    "wib_time_sync": {"nl_triggers": ["sync time", "time sync"], "params": {}},
    "wib_startup":   {"nl_triggers": ["initialize WIB", "WIB startup", "start WIB"], "params": {}},
    "cfg_push":      {"nl_triggers": ["push config", "upload config"], "params": {"operator": "str", "env": "RT|LN"}}
  },

  "layer1_power": {
    "femb_power_on": {
      "nl_triggers": ["power on", "turn on FEMB", "enable FEMB"],
      "params": {"slots": "list[0-3]", "env": "RT|LN"}
    },
    "femb_power_off": {
      "nl_triggers": ["power off", "turn off FEMB", "disable FEMB"],
      "params": {}
    }
  },

  "layer2_acquire": {
    "run_full_rms": {
      "nl_triggers": ["full RMS", "all configurations", "run full rms", "test all configs", "item5"],
      "params": {"slots": "list[0-3]", "operator": "str", "env": "RT|LN"},
      "note": "Phase 1: calls QC_top.py -t 5, acquires all 32 configurations"
    },
    "run_single_config": {
      "nl_triggers": ["single config", "specified config acquisition", "run single", "test this config only"],
      "params": {
        "slots": "list[0-3]",
        "snc":  "200mV|900mV",
        "gain": "4.7mV/fC|7.8mV/fC|14mV/fC|25mV/fC",
        "peaking": "0.5us|1us|2us|3us",
        "num_samples": "int"
      },
      "note": "Phase 2: calls atomic script sequence, acquires target configuration only"
    },
    "run_config_matrix": {
      "nl_triggers": ["config matrix", "multiple configs", "config matrix"],
      "params": {
        "slots": "list[0-3]",
        "snc_list": "list[200mV|900mV]",
        "gain_list": "list[...]",
        "peaking_list": "list[...]"
      }
    }
  },

  "layer3_analysis": {
    "analyze_from_manifest": {
      "nl_triggers": ["analyze", "view RMS", "show results", "what is baseline"],
      "params": {
        "femb_id": "int",
        "snc_label": "200mV|900mV|null",
        "gain_label": "str|null",
        "peaking_label": "str|null",
        "chips": "list[chip_id or silkscreen]|null",
        "chip_channels": "dict|null",
        "global_channels": "list[int]|null"
      }
    }
  },

  "param_synonyms": {
    "snc": {
      "200mV baseline": "200mV", "200mVBL": "200mV", "low baseline": "200mV",
      "900mV baseline": "900mV", "900mVBL": "900mV", "high baseline": "900mV"
    },
    "gain": {
      "14": "14mV/fC", "14mVfC": "14mV/fC",
      "25": "25mV/fC", "7.8": "7.8mV/fC", "4.7": "4.7mV/fC"
    },
    "peaking": {
      "2us": "2us", "0.5us": "0.5us", "1us": "1us", "3us": "3us"
    },
    "chip": {
      "U3": "U03", "U7": "U07", "chip0": 0, "chip3": 3
    },
    "env": {
      "liquid nitrogen": "LN", "LN2": "LN", "cold test": "LN", "room temperature": "RT", "warm": "RT"
    }
  }
}
